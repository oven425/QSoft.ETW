        <qpanel:FlexPanel AlignItems="Center" FlexDirection="Row" DockPanel.Dock="Top" Gap="6">
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="追蹤秒數："/>
            <TextBox Width="100"  Text="{Binding DurationSeconds, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="開始擷取並分析" Click="Capture_Click"/>
            <Button Content="分析既有檔案" Click="Analyze_Click"/>
        </qpanel:FlexPanel>
        <qpanel:FlexPanel AlignItems="Center" FlexDirection="Row" DockPanel.Dock="Top" Gap="6">
            <TextBlock Text="ETL 檔案："/>
            <TextBox IsReadOnly="True" qpanel:FlexPanel.Grow="1" Text="{Binding EtlPath, UpdateSourceTrigger=PropertyChanged}"/>
        </qpanel:FlexPanel>
        <qpanel:FlexPanel AlignItems="Center" FlexDirection="Row" DockPanel.Dock="Top" Gap="6">
            <TextBlock Text="{Binding Status}"/>
            <TextBlock Foreground="Firebrick" Text="{Binding ErrorMessage}" TextWrapping="Wrap"/>
        </qpanel:FlexPanel>
        <TabControl>
            <TabItem Header="CPU">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
					    <RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<scottPlot:WpfPlot x:Name="CpuPlot"/>
					<DataGrid Grid.Row="1" ItemsSource="{Binding Result.Analysis.ProcessCpuSummaries}" AutoGenerateColumns="True" IsReadOnly="True"/>
				</Grid>
			</TabItem>
            <TabItem Header="能源與電錶">
                <DataGrid ItemsSource="{Binding Result.Analysis.ProcessEnergySummaries}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Profile 熱點">
                <DataGrid ItemsSource="{Binding Result.Analysis.ProfileHotspots}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="DPC 熱點">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <scottPlot:WpfPlot x:Name="DpcPlot"/>
                    <CheckBox x:Name="DpcSelectAllCheckBox" Grid.Row="1" Content="全選" Margin="0,4" IsChecked="True" Click="DpcSelectAllCheckBox_Click"/>
                    <DataGrid x:Name="DpcDataGrid" Grid.Row="2" ItemsSource="{Binding DpcHotspots}" AutoGenerateColumns="True" IsReadOnly="False" AutoGeneratingColumn="DpcDataGrid_AutoGeneratingColumn">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="顯示" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Interrupt 熱點">
                <DataGrid ItemsSource="{Binding Result.Analysis.InterruptHotspots}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="資料品質">
                <ListBox ItemsSource="{Binding Result.Analysis.DataQualityWarnings}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
