                <Button Content="取消" Click="Cancel_Click" IsEnabled="{Binding IsBusy}"/>
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding Status}"/>
                <TextBlock Margin="12,0,0,0" Foreground="Firebrick" VerticalAlignment="Center" Text="{Binding ErrorMessage}" TextWrapping="Wrap"/>
            </StackPanel>
